---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectTagPosts, sortTags, tagHref } from "../../data/blog";

const posts = await getCollection("blog");
const sortedTags = sortTags(collectTagPosts(posts).entries());
---

<BaseLayout title="Tags" description="Blog tags by topic.">
  <main class="page-shell">
    <section class="page-hero">
      <p class="eyebrow">Tags</p>
      <h1><span class="section-marker" aria-hidden="true">§1</span>Browse by topic.</h1>
      <p class="lede">{sortedTags.length} tags</p>
    </section>

    <section class="content-band">
      <div class="tag-grid">
        {sortedTags.map(([tag, count]) => (
          <a
            class="tag-pill"
            href={tagHref(tag)}
          >
            {tag}
            <span class="tag-pill__count">{count.length}</span>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
