---
import { type CollectionEntry, getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  collectTagPosts,
  displayTag as displayFromRaw,
  postHref,
  sortBlogPosts,
  tagHref,
  tagSlug
} from "../../data/blog";
import { withBasePath } from "../../data/site";

interface TagPageData {
  displayTag: string;
  taggedPosts: CollectionEntry<"blog">[];
}

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tagPosts = collectTagPosts(posts);

  return [...tagPosts.entries()].map(([display, taggedPosts]) => ({
    params: { tag: tagSlug(display) },
    props: { displayTag: display, taggedPosts } satisfies TagPageData
  }));
}

const { displayTag, taggedPosts } = Astro.props as TagPageData;

const sortedPosts = sortBlogPosts(taggedPosts);
---

<BaseLayout
  title={`Tag: ${displayTag}`}
  description={`Blog posts tagged with "${displayTag}".`}
>
  <main class="page-shell">
    <section class="page-hero">
      <p class="eyebrow">
        <a href={withBasePath("/tags/")}>Tags</a>
      </p>
      <h1>{displayTag}</h1>
      <p class="lede">{sortedPosts.length} {sortedPosts.length === 1 ? "post" : "posts"}</p>
    </section>

    <section class="content-band">
      <div class="blog-list">
        {sortedPosts.map((post) => (
          <article class="blog-card">
            <div class="blog-card__meta">
              <time datetime={new Date(post.data.date).toISOString()}>
                {new Date(post.data.date).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric"
                })}
              </time>
            </div>
            <h2>
              <a href={postHref(post)}>
                {post.data.title}
              </a>
            </h2>
            <p>{post.data.summary}</p>
            <ul class="tag-list">
              {post.data.tags.map((t) => (
                <li><a href={tagHref(displayFromRaw(t))}>{displayFromRaw(t)}</a></li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
