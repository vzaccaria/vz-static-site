---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  publicCv,
  renderInlineMarkdown,
  toParagraphs,
  yearOf
} from "../../data/public-content";

const bioParagraphs = toParagraphs(publicCv.basics.officialDeptPage);
const education = publicCv.education;
const appointments = [...publicCv.work.previous].sort(
  (left, right) => right.index - left.index
);
---

<BaseLayout
  title="Bio"
  description="Biography, appointments, education, and contact details for Vittorio Zaccaria."
>
  <main class="page-shell">
    <section class="page-hero">
      <div>
        <p class="eyebrow">Bio</p>
        <h1><span class="section-marker" aria-hidden="true">§1</span>Academic biography</h1>
        {
          bioParagraphs.map((paragraph) => (
            <p class="lede"><Fragment set:html={renderInlineMarkdown(paragraph)} /></p>
          ))
        }
      </div>
    </section>

    <section class="content-band">
      <div class="section-heading">
        <p class="section-kicker">Appointments</p>
        <h2><span class="section-marker" aria-hidden="true">§2</span>Academic and industrial path</h2>
      </div>
      <div class="timeline">
        {
          appointments.map((appointment) => (
            <article>
              <span class="timeline-date">
                {yearOf(appointment.startDate)}
                {appointment.endDate ? `-${yearOf(appointment.endDate)}` : "-present"}
              </span>
              <div>
                <h3>{appointment.position}</h3>
                <p>{appointment.company}, {appointment.address}</p>
                <ul>
                  {appointment.highlights.slice(0, 3).map((highlight) => <li>{highlight}</li>)}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-band">
      <div class="section-heading">
        <p class="section-kicker">Education</p>
        <h2><span class="section-marker" aria-hidden="true">§3</span>Degrees</h2>
      </div>
      <div class="item-grid item-grid--two">
        {
          education.map((item) => (
            <article class="detail-card">
              <p class="meta">{yearOf(item.startDate)}-{yearOf(item.endDate)}</p>
              <h3>{item.studyType} in {item.area}</h3>
              <p>{item.institution}</p>
              <p>{item.topic}</p>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
