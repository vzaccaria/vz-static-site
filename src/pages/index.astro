---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  currentCourses,
  groupStatement,
  profileImagePath,
  publicCv,
  publicationStats,
  sortedTheses,
  toParagraphs
} from "../data/public-content";
import { withBasePath } from "../data/site";

const summaryParagraphs = toParagraphs(publicCv.basics.websiteSummary);
const latestCourse = currentCourses[0];
const topTheses = sortedTheses.slice(0, 3);
const profileImageSrc = withBasePath(profileImagePath);
---

<BaseLayout>
  <main class="page-shell">
    <section class="hero hero--profile">
      <div class="hero-copy">
        <p class="eyebrow">{publicCv.basics.label}</p>
        <h1>{publicCv.basics.name}</h1>
        {
          summaryParagraphs.map((paragraph) => (
            <p class="lede">{paragraph}</p>
          ))
        }
        <div class="action-row" aria-label="Primary actions">
          <a class="button button--primary" href={withBasePath("/research/")}>Research</a>
          <a class="button" href={withBasePath("/theses/")}>Thesis topics</a>
        </div>
      </div>

      <figure class="profile-figure">
        <img
          src={profileImageSrc}
          alt=""
          width="1367"
          height="1300"
          loading="eager"
        />
        <figcaption>
          <strong>{publicCv.work.current.position}</strong>
          <span>{publicCv.work.current.company}</span>
        </figcaption>
      </figure>
    </section>

    <section class="metric-strip" aria-label="Academic profile summary">
      <div>
        <strong>{publicationStats.total}</strong>
        <span>publications</span>
      </div>
      <div>
        <strong>{publicCv.research.impact.scholar.hindex}</strong>
        <span>Google Scholar h-index</span>
      </div>
      <div>
        <strong>{currentCourses.length}</strong>
        <span>current course</span>
      </div>
      <div>
        <strong>{sortedTheses.length}</strong>
        <span>open thesis areas</span>
      </div>
    </section>

    <section class="feature-grid" aria-label="Main site areas">
      <article>
        <p class="section-kicker">Research</p>
        <h2>Embedded systems, security, hardware design, and software tools.</h2>
        <p>{groupStatement}</p>
        <a class="text-link" href={withBasePath("/research/")}>View research profile</a>
      </article>

      <article>
        <p class="section-kicker">Teaching</p>
        <h2>{latestCourse?.courseName ?? "Courses"}</h2>
        <p>
          Current and past courses at Politecnico di Milano, including advanced
          operating systems, embedded virtualisation, and computer architecture.
        </p>
        <a class="text-link" href={withBasePath("/courses/")}>Browse courses</a>
      </article>

      <article>
        <p class="section-kicker">Theses</p>
        <h2>Active thesis directions</h2>
        <ul class="plain-list">
          {
            topTheses.map((thesis) => (
              <li>
                <span>{thesis.topic}</span>
                <strong>{thesis.title}</strong>
              </li>
            ))
          }
        </ul>
        <a class="text-link" href={withBasePath("/theses/")}>See thesis topics</a>
      </article>
    </section>
  </main>
</BaseLayout>
