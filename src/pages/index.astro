---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  currentCourses,
  groupStatement,
  latestPublications,
  profileImagePath,
  publicCv,
  renderInlineMarkdown,
  sortedTheses,
  toParagraphs
} from "../data/public-content";
import { withBasePath } from "../data/site";

const summaryParagraphs = toParagraphs(publicCv.basics.websiteSummary);
const latestCourse = currentCourses[0];
const topTheses = sortedTheses.slice(0, 3);
const recentOutput = latestPublications.slice(0, 5);
const officeLine = `${publicCv.basics.office.department} · ${publicCv.basics.office.address} · ${publicCv.basics.office.postalCode} ${publicCv.basics.office.city}`;
const affiliationLine = `${publicCv.work.current.company}`;
const profileImageSrc = withBasePath(profileImagePath);
const formatPublicationDate = (publication: (typeof latestPublications)[number]) =>
  new Date(publication.timestamp * 1000).toISOString().slice(0, 7);
const publicationVenue = (publication: (typeof latestPublications)[number]) =>
  publication.journal?.name ??
  publication.booktitle ??
  publication.publisher ??
  publication.institution ??
  publication.type;
const publicationMeta = (publication: (typeof latestPublications)[number]) =>
  [
    publication.authors.join(", "),
    publicationVenue(publication),
    publication.pages ? `pp ${publication.pages}` : undefined
  ]
    .filter(Boolean)
    .join(" · ");
---

<BaseLayout>
  <main class="page-shell">
    <section class="hero hero--profile">
      <div class="hero-copy">
        <p class="eyebrow">§ 1 · Profile overview</p>
        <h1>{publicCv.basics.name}</h1>
        <p class="hero-subline">{affiliationLine}</p>
        <div class="statement-list">
          {
            summaryParagraphs.map((paragraph, index) => (
              <p>
                <span class="statement-number">§1.{index + 1}</span>
                <span><Fragment set:html={renderInlineMarkdown(paragraph)} /></span>
              </p>
            ))
          }
        </div>
        <nav class="inline-actions" aria-label="Primary actions">
          <a class="text-link" href={withBasePath("/research/")}>research profile</a>
          <a class="text-link" href={withBasePath("/theses/")}>thesis topics</a>
        </nav>
      </div>

      <figure class="profile-figure profile-figure--home">
        <img
          src={profileImageSrc}
          alt="Vittorio Zaccaria"
          width="1367"
          height="1300"
          loading="eager"
        />
        <figcaption>
          <strong>{publicCv.work.current.position}</strong>
          <span>{publicCv.work.current.company}</span>
          <span>{officeLine}</span>
          <span>{publicCv.basics.email}</span>
        </figcaption>
      </figure>
    </section>

    <section class="content-band home-output">
      <div class="table-heading">
        <p>Table 2 - Recent output</p>
        <h2 class="visually-hidden">Recent output</h2>
      </div>
      <div class="publication-list publication-list--datasheet">
        {
          recentOutput.map((publication) => (
            <article>
              <p class="meta">{formatPublicationDate(publication)}</p>
              <div>
                <h3>
                  {
                    publication.url ? (
                      <a href={publication.url}>{publication.title}</a>
                    ) : (
                      publication.title
                    )
                  }
                </h3>
                <p>{publicationMeta(publication)}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="feature-grid" aria-label="Main site areas">
      <article>
        <p class="section-kicker">Research</p>
        <h2><span class="section-marker" aria-hidden="true">§2</span>Embedded systems, security, hardware design, and software tools.</h2>
        <p>{groupStatement}</p>
        <a class="text-link" href={withBasePath("/research/")}>View research profile</a>
      </article>

      <article>
        <p class="section-kicker">Teaching</p>
        <h2><span class="section-marker" aria-hidden="true">§3</span>{latestCourse?.courseName ?? "Courses"}</h2>
        <p>
          Current and past courses at Politecnico di Milano, including advanced
          operating systems, embedded virtualisation, and computer architecture.
        </p>
        <a class="text-link" href={withBasePath("/courses/")}>Browse courses</a>
      </article>

      <article>
        <p class="section-kicker">Theses</p>
        <h2><span class="section-marker" aria-hidden="true">§4</span>Active thesis directions</h2>
        <ul class="plain-list">
          {
            topTheses.map((thesis) => (
              <li>
                <span>{thesis.topic}</span>
                <strong>{thesis.title}</strong>
              </li>
            ))
          }
        </ul>
        <a class="text-link" href={withBasePath("/theses/")}>See thesis topics</a>
      </article>
    </section>
  </main>
</BaseLayout>
