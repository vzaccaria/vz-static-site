---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  highlightedGrants,
  latestPublications,
  publicationStats,
  publicCv,
  researchAreas,
  selectedProjects,
  toParagraphs,
  yearOf
} from "../../data/public-content";

const goalParagraphs = toParagraphs(publicCv.research.currentGoals.short);
const metrics = [
  { label: "Publications", value: publicationStats.total },
  { label: "Journal papers", value: publicationStats.journals },
  { label: "Conference papers", value: publicationStats.conferences },
  { label: "Patents", value: publicationStats.patents }
];
---

<BaseLayout
  title="Research"
  description="Research interests, projects, grants, and selected publications by Vittorio Zaccaria."
>
  <main class="page-shell">
    <section class="page-hero">
      <p class="eyebrow">Research</p>
      <h1><span class="section-marker" aria-hidden="true">§1</span>Embedded systems, security, and hardware/software design.</h1>
      {
        goalParagraphs.map((paragraph) => (
          <p class="lede">{paragraph}</p>
        ))
      }
    </section>

    <section class="metric-strip" aria-label="Research output summary">
      {
        metrics.map((metric) => (
          <div>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))
      }
    </section>

    <section class="content-band">
      <div class="section-heading">
        <p class="section-kicker">Directions</p>
        <h2><span class="section-marker" aria-hidden="true">§2</span>Current research areas</h2>
      </div>
      <div class="item-grid item-grid--three">
        {
          researchAreas.map((area) => (
            <article class="detail-card">
              <h3>{area.area}</h3>
              <ul class="tag-list tag-list--light">
                {area.keywords.map((keyword) => <li>{keyword}</li>)}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-band">
      <div class="section-heading">
        <p class="section-kicker">Selected work</p>
        <h2><span class="section-marker" aria-hidden="true">§3</span>Recent publications</h2>
      </div>
      <div class="publication-list">
        {
          latestPublications.map((publication) => (
            <article>
              <p class="meta">{publication.year} · {publication.type}</p>
              <h3>
                {
                  publication.url ? (
                    <a href={publication.url}>{publication.title}</a>
                  ) : (
                    publication.title
                  )
                }
              </h3>
              <p>
                {publication.journal?.name ?? publication.booktitle ?? publication.publisher ?? publication.institution}
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-band">
      <div class="section-heading">
        <p class="section-kicker">Projects</p>
        <h2><span class="section-marker" aria-hidden="true">§4</span>Research software and collaborations</h2>
      </div>
      <div class="item-grid item-grid--two">
        {
          selectedProjects.slice(0, 6).map((project) => (
            <article class="detail-card">
              <p class="meta">{project.timeframe} · {project.type}</p>
              <h3>
                {
                  project.link ? (
                    <a href={project.link}>{project.name}</a>
                  ) : (
                    project.name
                  )
                }
              </h3>
              <p>{project.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="content-band">
      <div class="section-heading">
        <p class="section-kicker">Grants</p>
        <h2><span class="section-marker" aria-hidden="true">§5</span>Highlighted funding</h2>
      </div>
      <div class="compact-list">
        {
          highlightedGrants.map((grant) => (
            <article>
              <span>{yearOf(grant.from)}-{yearOf(grant.to)}</span>
              <div>
                <h3>{grant.project}</h3>
                <p>{grant.type}, {grant.institution}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
