---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  publicCv
} from "../../data/public-content";

type Course = (typeof publicCv.teaching.courses)[number];

const courseRegistry = [...publicCv.teaching.courses].sort(
  (left, right) => right.aaEnd - left.aaEnd || right.aaInit - left.aaInit
);

const formatAcademicYearLong = (course: Course) =>
  course.aaInit === course.aaEnd
    ? `${course.aaInit}`
    : `${course.aaInit}/${course.aaEnd}`;
const courseCredits = (course: Course) => {
  const value = String(course.crediti ?? "").trim();
  return value && value.toUpperCase() !== "N" ? value : "-";
};
const courseLevel = (course: Course) => {
  const source = `${course.type ?? ""} ${course.level} ${course.short ?? ""}`.toLowerCase();
  const hasMs = /magistrale|specialistica|quinquennale|lm|master/.test(source);
  const hasPhd = /ph\.?d|dottor/.test(source);

  if (hasPhd && hasMs) return "PHD/MS";
  if (hasPhd) return "PHD";
  if (hasMs) return "MS";
  if (/primo livello|triennale|bachelor/.test(source)) return "BS";
  return "-";
};
const courseTrack = (course: Course) => {
  const source = `${course.level} ${course.short ?? ""}`.toLowerCase();

  if (/meccanica|energetica|mec|eng/.test(source)) return "MEC/ENG";
  if (/elettronica|biomedica|elett|bio/.test(source)) return "ELN/BIO";
  if (/informatica|ing\. inf/.test(source)) return "INF";
  if (/elettrica/.test(source)) return "ELN";
  if (/design/.test(source)) return "DES";
  return "-";
};
---

<BaseLayout
  title="Courses"
  description="Current and past courses taught by Vittorio Zaccaria."
>
  <main class="page-shell">
    <section class="page-hero page-hero--compact">
      <p class="eyebrow">§ 2 · Teaching</p>
      <h1>Courses</h1>
      <p class="lede">
        Current and past courses (with links to webpages if still active).
      </p>
    </section>

    <section class="content-band content-band--table courses-registry">
      <div class="table-heading">
        <p>Table 1 - Courses registry</p>
        <h2 class="visually-hidden">Courses registry</h2>
      </div>
      <div class="registry-table" role="table" aria-label="Courses registry">
        <div class="registry-table__head" role="row">
          <span role="columnheader">AA</span>
          <span role="columnheader">Course</span>
          <span role="columnheader">CR</span>
          <span role="columnheader">Level</span>
          <span role="columnheader">Track</span>
          <span role="columnheader">Web</span>
        </div>
        {
          courseRegistry.map((course) => (
            <article class="registry-row" role="row">
              <span role="cell">{formatAcademicYearLong(course)}</span>
              <strong class="registry-row__course" role="cell">{course.courseName}</strong>
              <span role="cell">{courseCredits(course)}</span>
              <span role="cell">{courseLevel(course)}</span>
              <span role="cell">{courseTrack(course)}</span>
              <span role="cell">
                {
                  course.link ? (
                    <a class="registry-row__web" href={course.link}>open</a>
                  ) : (
                    "-"
                  )
                }
              </span>
            </article>
          ))
        }
      </div>
    </section>
  </main>
</BaseLayout>
