---
import { primaryNavigation } from "../data/navigation";
import { siteMetadata, withBasePath } from "../data/site";
import "../styles/global.css";
import "../styles/ds/fonts.css";
import "../styles/ds/tokens.css";
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
}

const {
  title = siteMetadata.title,
  description = siteMetadata.description,
  image = siteMetadata.image,
  type = "website",
  publishedTime
} = Astro.props;

const pageTitle =
  title === siteMetadata.title ? title : `${title} | ${siteMetadata.shortName}`;
const siteUrl = Astro.site ?? new URL(siteMetadata.url);
const canonical = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(withBasePath(image), siteUrl);
const feedUrl = new URL(withBasePath("/feed.xml"), siteUrl);
---

<!doctype html>
<html lang={siteMetadata.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" href={withBasePath("favicon.svg")} type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteMetadata.title} feed`}
      href={feedUrl.toString()}
    />
    <meta property="og:site_name" content={siteMetadata.title} />
    <meta property="og:locale" content={siteMetadata.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" aria-label="Primary">
      <a class="brand" href={withBasePath("/")} aria-label={siteMetadata.title}>
        <span class="brand-mark">VZ</span>
        <span>{siteMetadata.title}</span>
      </a>
      <nav aria-label="Main navigation">
        {
          primaryNavigation.map((item) => (
            <a href={withBasePath(item.href)}>{item.label}</a>
          ))
        }
      </nav>
    </header>
    <div id="content">
      <slot />
    </div>
  </body>
</html>
