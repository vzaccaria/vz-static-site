---
import { primaryNavigation } from "../data/navigation";
import { publicCv } from "../data/public-content";
import { siteMetadata, withBasePath } from "../data/site";
import monoBoldFontUrl from "../styles/ds/fonts/IBMPlexMono-Bold.otf?url";
import monoMediumFontUrl from "../styles/ds/fonts/IBMPlexMono-Medium.otf?url";
import monoRegularFontUrl from "../styles/ds/fonts/IBMPlexMono-Regular.otf?url";
import monoSemiBoldFontUrl from "../styles/ds/fonts/IBMPlexMono-SemiBold.otf?url";
import sansBoldFontUrl from "../styles/ds/fonts/IBMPlexSans-Bold.otf?url";
import sansRegularFontUrl from "../styles/ds/fonts/IBMPlexSans-Regular.otf?url";
import "../styles/global.css";
import "../styles/ds/fonts.css";
import "../styles/ds/tokens.css";
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
}

const {
  title = siteMetadata.title,
  description = siteMetadata.description,
  image = siteMetadata.image,
  type = "website",
  publishedTime
} = Astro.props;

const pageTitle =
  title === siteMetadata.title ? title : `${title} | ${siteMetadata.shortName}`;
const siteUrl = Astro.site ?? new URL(siteMetadata.url);
const canonical = new URL(Astro.url.pathname, siteUrl);
const ogImage = new URL(withBasePath(image), siteUrl);
const feedUrl = new URL(withBasePath("/feed.xml"), siteUrl);
const revision = "2026.06";
const normalizedPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const isCurrentNavItem = (href: string) => {
  const target = withBasePath(href);
  return href === "/" ? normalizedPath === target : normalizedPath.startsWith(target);
};
const socialLinks = Object.fromEntries(
  publicCv.basics.social.map((item) => [item.network.toLowerCase(), item.url])
);
const criticalFontPreloads = [
  sansRegularFontUrl,
  sansBoldFontUrl,
  monoRegularFontUrl,
  monoMediumFontUrl,
  monoSemiBoldFontUrl,
  monoBoldFontUrl
];
---

<!doctype html>
<html lang={siteMetadata.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="icon" href={withBasePath("favicon.svg")} type="image/svg+xml" />
    {
      criticalFontPreloads.map((fontUrl) => (
        <link rel="preload" href={fontUrl} as="font" type="font/otf" crossorigin />
      ))
    }
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteMetadata.title} feed`}
      href={feedUrl.toString()}
    />
    <meta property="og:site_name" content={siteMetadata.title} />
    <meta property="og:locale" content={siteMetadata.locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={ogImage.toString()} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <header class="site-header" aria-label="Primary">
      <div class="site-header__inner">
        <a class="brand" href={withBasePath("/")} aria-label={siteMetadata.title}>
          <span class="brand-mark" aria-hidden="true">{siteMetadata.shortName}</span>
          <span class="brand-copy">
            <span class="brand-title">{siteMetadata.title}</span>
            <span class="brand-meta">Rev. {revision}</span>
          </span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {
            primaryNavigation.map((item, index) => (
              <a
                href={withBasePath(item.href)}
                aria-current={isCurrentNavItem(item.href) ? "page" : undefined}
              >
                <span class="nav-number">{String(index + 1).padStart(2, "0")}</span>
                <span class="nav-label">{item.label}</span>
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <div id="content">
      <slot />
    </div>
    <footer class="site-footer">
      <nav class="footer-links" aria-label="Secondary links">
        <a href={`mailto:${publicCv.basics.email}`}>mail</a>
        {socialLinks.github && <a href={socialLinks.github}>github</a>}
        {socialLinks.linkedin && <a href={socialLinks.linkedin}>linkedin</a>}
        <a href={feedUrl.toString()}>rss</a>
      </nav>
      <p>
        <span>Doc {siteMetadata.shortName}-001</span>
        <strong>Rev. {revision}</strong>
      </p>
    </footer>
  </body>
</html>
