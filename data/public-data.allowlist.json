{
  "version": 1,
  "description": "Allowlisted fields that may be copied from a private export into src/data/generated/public-data.json.",
  "output": "src/data/generated/public-data.json",
  "fields": [
    "profile.name",
    "profile.title",
    "profile.affiliation",
    "profile.summary",
    "profile.publicEmail",
    "profile.links[].label",
    "profile.links[].url",
    "researchAreas[].id",
    "researchAreas[].title",
    "researchAreas[].summary",
    "researchAreas[].tags[]",
    "courses[].id",
    "courses[].title",
    "courses[].level",
    "courses[].academicYear",
    "courses[].summary",
    "courses[].url",
    "theses[].id",
    "theses[].title",
    "theses[].status",
    "theses[].topics[]",
    "theses[].summary",
    "publications[].id",
    "publications[].title",
    "publications[].year",
    "publications[].venue",
    "publications[].authors[]",
    "publications[].doi",
    "publications[].url",
    "posts[].slug",
    "posts[].title",
    "posts[].description",
    "posts[].pubDate",
    "posts[].tags[]",
    "posts[].draft"
  ],
  "required": [
    "schemaVersion",
    "profile.name",
    "profile.affiliation"
  ],
  "blockedKeyPatterns": [
    "(^|[_-])(private|secret|token|password|credential|internal|confidential)([_-]|$)",
    "(^|[_-])notes?([_-]|$)"
  ]
}
